```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled and build artifacts
*.o
*.obj
*.out
dist/
build/
target/

# Dependencies
.venv/
venv/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# Coverage
.coverage
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/
```